<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <springProperty scope="context" name="LOG_FORMAT" source="LOG_FORMAT" defaultValue="plain"/>
  <springProperty scope="context" name="LOG_LEVEL" source="LOG_LEVEL" defaultValue="INFO"/>

  <property name="PLAIN_PATTERN" value="%d{yyyy-MM-dd\'T\'HH:mm:ss.SSSXXX} %-5level [%thread] %logger{36} request_id=%X{request_id:-} run_id=%X{run_id:-} app_mode=%X{app_mode:-} provider_id=%X{provider_id:-} - %msg%n"/>

  <appender name="CONSOLE_PLAIN" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>${PLAIN_PATTERN}</pattern>
    </encoder>
  </appender>

  <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
    <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
      <providers>
        <timestamp/>
        <logLevel/>
        <threadName/>
        <loggerName/>
        <message/>
        <mdc/>
        <stackTrace/>
        <arguments/>
      </providers>
      <customFields>{"service":"plan-service"}</customFields>
    </encoder>
  </appender>

  <!-- Low-noise access log is routed to its own logger name -->
  <logger name="access" level="INFO" additivity="false">
    <if condition='property("LOG_FORMAT").equals("json")'>
      <then>
        <appender-ref ref="CONSOLE_JSON"/>
      </then>
      <else>
        <appender-ref ref="CONSOLE_PLAIN"/>
      </else>
    </if>
  </logger>

  <root level="${LOG_LEVEL}">
    <if condition='property("LOG_FORMAT").equals("json")'>
      <then>
        <appender-ref ref="CONSOLE_JSON"/>
      </then>
      <else>
        <appender-ref ref="CONSOLE_PLAIN"/>
      </else>
    </if>
  </root>
</configuration>
